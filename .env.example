# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ─── AI Assistant ─────────────────────────────────────────────────────────────
# The AI Assistant chat (src/pages/AiAssistant.tsx) calls the `chat-ai` Supabase
# Edge Function, which needs its own GEMINI_API_KEY (free tier via Google AI
# Studio: https://aistudio.google.com/apikey) — set as a Supabase secret, never
# a VITE_ var (that would ship it to the browser):
#   supabase secrets set GEMINI_API_KEY=AIza...
